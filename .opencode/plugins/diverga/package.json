{
  "name": "diverga-opencode-plugin",
  "version": "10.3.1",
  "description": "Diverga Research Coordinator - Multi-agent system for social science research (OpenCode Plugin)",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "npx vitest run",
    "test:watch": "npx vitest",
    "test:coverage": "npx vitest run --coverage",
    "test:memory": "npx vitest run __tests__/memory.test.ts",
    "test:hud": "npx vitest run __tests__/hud.test.ts"
  },
  "keywords": [
    "opencode",
    "plugin",
    "research",
    "social-science",
    "meta-analysis",
    "systematic-review",
    "diverga"
  ],
  "author": "Hosung You",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.2",
    "typescript": "5.3",
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0"
  },
  "files": [
    "dist",
    "hooks"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/HosungYou/Diverga.git",
    "directory": ".opencode/plugins/diverga"
  }
}
