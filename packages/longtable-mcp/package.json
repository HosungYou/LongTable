{
  "name": "@longtable/mcp",
  "version": "0.1.19",
  "private": false,
  "description": "LongTable MCP transport for workspace state and Researcher Checkpoints",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "longtable-state": "bin/longtable-state"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "self-test": "node ./dist/server.js --self-test"
  },
  "dependencies": {
    "@longtable/checkpoints": "0.1.19",
    "@longtable/cli": "0.1.19",
    "@longtable/core": "0.1.19",
    "@longtable/provider-claude": "0.1.19",
    "@longtable/provider-codex": "0.1.19",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "longtable",
    "mcp",
    "research",
    "checkpoints"
  ],
  "author": "Hosung You",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HosungYou/LongTable.git"
  },
  "homepage": "https://github.com/HosungYou/LongTable#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
