{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/plugins/diverga/hooks/prereq-enforcer.mjs",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "node $HOME/.claude/plugins/diverga/hooks/prereq-enforcer.mjs",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
